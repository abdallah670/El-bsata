# ─── Wasat Elbasata API — Environment Variables ──────────────────────────────
#
# Copy this file to .env.local and fill in your values.
# In PowerShell set them with:
#   $env:SMTP__USER = "you@gmail.com"
#   $env:SMTP__PASS = "your-app-password"
#
# In bash/Linux:
#   export SMTP__USER=you@gmail.com
#   export SMTP__PASS=your-app-password
#
# NOTE: Double underscore (__) is .NET's env-var hierarchy separator.
#       SMTP__HOST maps to config key "Smtp:Host"

SMTP__HOST=smtp.gmail.com
SMTP__PORT=587
SMTP__USER=your-email@gmail.com
SMTP__PASS=your-gmail-app-password
SMTP__RECIPIENT=kitchen@yourrestaurant.com
